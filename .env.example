OPENAI_API_KEY=1234

LANGSMITH_API_KEY=1234
LANGSMITH_PROJECT=1234
LANGSMITH_TRACING=true

# Slack bot (cosmere-slack)
# Required scopes: app_mentions:read, chat:write, im:history, im:read, im:write
# Event subscriptions: app_mention, message.im
# Enable Socket Mode in your app config; xapp- token must have connections:write
SLACK_APP_TOKEN=xapp1234
SLACK_BOT_TOKEN=xoxb1234
# When true, the bot includes the LangSmith trace URL in each Slack reply.
# Keep false for shared workspaces; turn on for local debugging.
SLACK_INCLUDE_TRACE_URL=false

# BigQuery retrieval backend (used by cosmere-slack)
GOOGLE_CLOUD_PROJECT=1234
BIGQUERY_DATASET=cosmere_rag
BIGQUERY_TABLE=era1
BIGQUERY_LOCATION=US
EMBEDDING_MODEL=text-embedding-3-small
